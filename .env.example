# ---- Azure OpenAI (for STT: whisper / gpt-4o-transcribe / gpt-4o-mini-transcribe) ----
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=sk-...
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Deployment names you created in Azure AI Foundry (change to match your deployments)
AZURE_STT_WHISPER_DEPLOYMENT=whisper
AZURE_STT_GPT4O_TRANSCRIBE_DEPLOYMENT=gpt-4o-transcribe
AZURE_STT_GPT4O_MINI_TRANSCRIBE_DEPLOYMENT=gpt-4o-mini-transcribe

# ---- Azure AI Foundry text models (for refinement) ----
AZURE_REFINE_GPT54_NANO_DEPLOYMENT=gpt-5.4-nano
AZURE_REFINE_GPT54_MINI_DEPLOYMENT=gpt-5.4-mini
AZURE_REFINE_HAIKU_DEPLOYMENT=claude-haiku-4-5
